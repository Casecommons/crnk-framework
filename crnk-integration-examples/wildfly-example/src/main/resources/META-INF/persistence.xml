<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<persistence xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
			 version="3.0"
			 xs:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
			 xmlns="https://jakarta.ee/xml/ns/persistence">

	<persistence-unit name="TEST_WILDFLY" transaction-type="RESOURCE_LOCAL">
		<properties>
			<property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
			<property name="jakarta.persistence.jdbc.url" value="jdbc:h2:mem"/>
			<property name="jakarta.persistence.jdbc.user" value="sa"/>

			<property name="hibernate.id.new_generator_mappings" value="true"/>
			<property name="hibernate.dialect" value="H2"/>
			<property name="hibernate.format_sql" value="false"/>
			<property name="hibernate.hbm2ddl.auto" value="create-drop"/>
			<property name="hibernate.validator.autoregister_listeners"
					  value="true"/>
		</properties>
	</persistence-unit>
</persistence>
